# HTML - Kurz cachen (Änderungen schnell sichtbar)
/*.html
  Cache-Control: public, max-age=3600, must-revalidate, stale-while-revalidate=86400
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin

# CSS/JS - Lang cachen (mit Hash-Versionierung)
/css/*
/js/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Images - 7 Tage cachen
/img/*
/medien/*
*.webp
*.jpg
*.png
*.jpeg
  Cache-Control: public, max-age=604800, stale-while-revalidate=604800

# Favicon - Sehr lang cachen
/favicon.svg
  Content-Type: image/svg+xml
  Cache-Control: public, max-age=31536000, immutable
/favicon-*.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable
/apple-touch-icon.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable
/browserconfig.xml
  Content-Type: application/xml
  Cache-Control: public, max-age=31536000, immutable

# Manifest - 1 Stunde
/manifest.json
  Content-Type: application/manifest+json
  Cache-Control: public, max-age=3600, must-revalidate

# Sitemap/Robots - 1 Tag
/sitemap.xml
/robots.txt
  Cache-Control: public, max-age=86400

# Security Headers für ALLE
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
